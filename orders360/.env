# Used by docker compose for the vulcan-api user: must match `id -u` / `id -g` on the host
# so the bind mount at .logs (and the rest of the project) is writable.
DOCKER_UID=1001
DOCKER_GID=1001

# Snowflake (required by vulcan-api) — replace with your real credentials
SNOWFLAKE_ACCOUNT= EQZOTUQ-JCA67320
SNOWFLAKE_USER= kishan
SNOWFLAKE_PASSWORD= Tmdc@1234567890
SNOWFLAKE_WAREHOUSE=SNOWFLAKE_LEARNING_WH
SNOWFLAKE_DATABASE=SNOWFLAKE_SAMPLE_DATA

# Optional
SNOWFLAKE_ROLE=
SNOWFLAKE_AUTHENTICATOR=snowflake
STATE_SCHEMA=vulcan_try

# Postgres infra host for both warehouse + state in config.yaml:
# - Docker CLI (`make vulcan-cli` / print-alias): leave unset — Makefile forces statestore:5432 after .env.
# - Host-installed `vulcan` only: uncomment to reach Docker-published Postgres on the host.
# VULCAN_STATESTORE_HOST=127.0.0.1
# VULCAN_STATESTORE_PORT=5431
#
# Bridge / DNS issues from inside Docker (needs --add-host=host.docker.internal:host-gateway in Makefile)
# VULCAN_STATESTORE_HOST=host.docker.internal
# VULCAN_STATESTORE_PORT=5431
